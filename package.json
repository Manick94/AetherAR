{
  "name": "aetherar",
  "version": "0.1.0",
  "private": true,
  "description": "Next-generation open source WebAR engine monorepo",
  "workspaces": [
    "packages/*",
    "packages/adapters/*",
    "packages/tools/*",
    "apps/*"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "typecheck": "tsc -b tsconfig.json --pretty false",
    "clean": "git clean -xdf -e node_modules",
    "demo:dev": "npm run dev --workspace @aetherar/demo",
    "demo:build": "npm run build --workspace @aetherar/demo"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
